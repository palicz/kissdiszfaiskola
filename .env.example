# PostgreSQL connection string (Vercel Postgres / Neon).
# Read by Payload CMS via src/payload.config.ts.
POSTGRES_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# JWT / session encryption secret (Payload CMS).
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public site URL.
# Production: https://example.com — Development: http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Bearer token for Payload cron / job endpoint (Authorization header).
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Live preview URL validation secret.
PREVIEW_SECRET=YOUR_SECRET_HERE

# Vercel Blob — media uploads.
# Provision via Vercel Dashboard → Storage → Blob.
# Optional locally; files fall back to local storage without this.
# BLOB_READ_WRITE_TOKEN=
