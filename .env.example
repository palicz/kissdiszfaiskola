# Postgres (Neon). A Payload ezt olvassa (src/payload.config.ts).
# Vercel + Neon integráció gyakran automatikusan beállítja a POSTGRES_URL-t.
POSTGRES_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# JWT / session titkosítás (Payload)
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Production: https://example.com — Development / lokális: http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Payload cron / job végpont (Authorization header)
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Live preview URL-ek validálása
PREVIEW_SECRET=YOUR_SECRET_HERE

# Vercel Blob — média feltöltés. Vercel: Storage → Blob → csatlakoztatás
# (általában BLOB_READ_WRITE_TOKEN). Lokálisan nélküle is: fájlok public/media alá.
# BLOB_READ_WRITE_TOKEN=
